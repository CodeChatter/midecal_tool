# 示例配置：请复制为 .env 后填写真实值，不要提交到版本库。
# cp .env.example .env

# ── Docker 资源（改完 docker compose up -d 即可生效，无需 rebuild）──
# P4 8GB / 4核 / 20GiB 推荐默认值：先保守运行，稳定后再逐步上调。
DOCKER_CPUS=4
DOCKER_MEM=18G
DOCKER_SHM_SIZE=2gb
# GPU 支持：设为 true 并修改 BASE_IMAGE 后需 rebuild
# CPU 模式用 deploy.sh cpu，GPU 模式用 deploy.sh gpu，会自动配置以下参数
INSTALL_GPU=false
BASE_IMAGE=python:3.11-slim
PADDLE_GPU_VERSION=3.1.1
PADDLE_CUDA_TAG=cu118
APP_WORKERS=1
HF_ENDPOINT=https://hf-mirror.com
HF_HUB_ENDPOINT=https://hf-mirror.com

# ── 应用并发 ──
# Docker 默认先走保守配置，确保启动后首个请求稳定；确认稳定后再逐步调大。
MAX_CONCURRENCY=2
# OCR 实例池大小（0=自动，GPU 模式下会自动收敛到 1）
OCR_POOL_SIZE=1
# OCR 模型：server（精度高，适合模糊图）或 mobile（速度快，适合清晰图）
OCR_MODEL=mobile
FLAGS_fraction_of_gpu_memory_to_use=0.6
OMP_NUM_THREADS=2
OPENBLAS_NUM_THREADS=1
MKL_NUM_THREADS=1
FLAGS_num_threads=1

# ── LLM 提供商（按需配置，DEFAULT_LLM_PROVIDER 选择使用哪个）──
DEFAULT_LLM_PROVIDER=openai

# OpenAI API 配置（推荐）
OPENAI_BASE_URL=
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o
OPENAI_VISION_DETAIL=auto

# Claude API 配置（备选）
ANTHROPIC_BASE_URL=
ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# 智谱 GLM Vision API 配置
# 当前官方文档标注 GLM-4.6V-Flash 为免费模型，适合先做接口联调和初步跑通测试。
ZHIPU_API_KEY=your_zhipu_api_key
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
ZHIPU_MODEL=GLM-4.6V-Flash

# 阿里云百炼 Qwen Vision 配置
BAILIAN_API_KEY=your_bailian_api_key
BAILIAN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
BAILIAN_MODEL=qwen3-vl-32b-instruct

# 火山引擎豆包 Vision 配置
ARK_API_KEY=your_ark_api_key
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_MODEL=doubao-seed-1-8-251228
ARK_MODEL_LITE=doubao-seed-2-0-lite-260215

# 低时延 Vision 参数
VISION_MAX_TOKENS=384
VISION_IMAGE_MAX_SIDE=1280
VISION_JPEG_QUALITY=75

# 腾讯云 COS 配置
COS_SECRET_ID=your_cos_secret_id
COS_SECRET_KEY=your_cos_secret_key
COS_REGION=ap-nanjing
COS_BUCKET=example-1250000000
COS_SCHEME=https
# 自定义域名映射（JSON），格式：{"域名": "bucket/region"}
# COS_DOMAIN_MAP={"cdn.example.com": "example-1250000000/ap-nanjing"}
COS_DOMAIN_MAP=
